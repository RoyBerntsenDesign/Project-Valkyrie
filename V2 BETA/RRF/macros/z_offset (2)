var PositionOfBedAnvilX = 151.5                                            ; Center point of anvil  from x0
var PositionOfBedAnvilY = -17                                             ; Center point of anvil  from Y0
var PositionOfBedSwitchX =154                                             ; Center point of Bed Switch from X0
var PositionOfBedSwitchY = -29                                            ; Center point of Bed Switch from Y0
var speed = 30000                                                         ; Speed of G1 moves
var avg = 0                                                               ; average results for nozzel offset calculation 
var avg1 = 0
;~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ Do Not alter anything below this line~~~~~~~~~~~~~~~~~~~~~~~~~

if sensors.probes[0].value[0]==1000                                       ; if sensor is value other than 1000 do this, 0 = probe attached
    M564 S0 H0   
    M98 P"/macros/probe_get"
      
; step 1 - probe bed
M564 S0                                                                   ; S1 = limit movement within axis boundaries, S0 = allow movement outside boundaries
G1  X153 Y177.5 F30000                                                    ; probe to center bed  
echo sensors.probes[0].lastStopHeight   
echo sensors.probes[1].lastStopHeight  	
G31 K0 Z0                                                                 ; clear Z offset
G31 K1 Z0                                                                 ; clear Z offset
G30 K0 F300
echo sensors.probes[0].lastStopHeight   
echo sensors.probes[1].lastStopHeight
G1 E-1                                                                    ; probe bed with a Single Z-Probe
; step 2 - probe 3 times on alvin and return offset value.
G1 F18000  X{var.PositionOfBedAnvilX} Y{var.PositionOfBedAnvilY}          ; move bed probe to alvin
G30 K0 P0 Z-9999
set var.avg = sensors.probes[0].lastStopHeight
G30 K0 P1 Z-9999 S-1
set var.avg = var.avg + sensors.probes[0].lastStopHeight 
;G30 K0 P2 Z-9999 S-1
;set var.avg = var.avg + sensors.probes[0].lastStopHeight
echo var.avg/2, "avg / 2"
G31 K0 Z{var.avg/2}                                                       ; set Z K0 offset 
G31 K1 Z{var.avg/2}                                                       ; set Z K1 offset
G1 X155 Y40 Z15                                                           ; Move toolhead and bed down to Z25
; step 3 - leave bed probe
M98 P"/macros/nozzle_park"
G1 E-2 F300  
M400
M98 P"/macros/nozzle_brush"                                               ; probe nozzle
; step 5 - probe nozzle with bed switch
G1 X{var.PositionOfBedSwitchX} Y{var.PositionOfBedSwitchY }  F{var.speed} ; move nozzle to probe bed switch
G30 K1                                                                    ; probe bed switch with nozzle 

G30 K1 P0 Z-9999
set var.avg1 = sensors.probes[1].lastStopHeight
echo sensors.probes[1].lastStopHeight
G30 K1 P1 Z-9999 S-1
set var.avg1 = var.avg1 + sensors.probes[1].lastStopHeight 
echo sensors.probes[1].lastStopHeight
;G30 K1 P2 Z-9999 S-1
;set var.avg1 = var.avg1 + sensors.probes[1].lastStopHeight
;echo sensors.probes[1].lastStopHeight
echo var.avg1/2, "K1 avg1 / 2"

G1 Z15
G1 E1 
echo sensors.probes[0].lastStopHeight, "K0"
echo sensors.probes[1].lastStopHeight, "K1"
G1 F30000 X155 Y15                                                        ; get nozzel back into bed area0
M400
M564 S1                                                                   ; S1 = limit movement within axis boundaries, S0 = allow movement outside boundaries