var Ytoolswitch_position = ((move.axes[1].max/ 2)-175)                   ; Postion of tool Switch from centre of bed Y axis
echo var.Yanvil_position ,var.Ytoolswitch_position                       ; Display distances
var speed = 30000                                                        ; Speed of G1 moves


;~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ Do Not alter anything below this line~~~~~~~~~~~~~~~~~~~~~~~~~

var avg = 0                                                                        ; Average results for nozzel offset calculation 
var avg1 = 0
if sensors.probes[0].value[0]==1000                                                ; 0= probe connected  , 1000 =  probe not connected                                                                                                                                                  ; 0= prabe attached 1000 = no probe attached 
    M564 S0 H0                                                                     ; Move outside print area
    M98 P"/macros/probe_get"
      
; step 1 - probe bed
M564 S0 H0                                                                         ; Move outside print area                                                                                                                                                                        ; S1 = limit movement within axis boundaries, S0 = allow movement outside boundaries
M98 P"0:/macros/probe_center"                                                      ; Probe to center bed  
echo sensors.probes[0].lastStopHeight, "K0 last stop height"                       ; K0 last stop height 
echo sensors.probes[1].lastStopHeight, "K10 last stop height"                      ; K0 last stop height 
G31 K0 Z0                                                                          ; Set K0 probe offset to 0                                                                                                                                                         ; clear Z offset
G31 K1 Z0                                                                          ; Set K1 probe offset to 0                                                                                                                                                          ; clear Z offset
G30 K0 F300                                                                        ; Probe centre of bed with K0
echo sensors.probes[0].lastStopHeight, "K0 last stop height"                       ; K0 last stop height 
echo sensors.probes[1].lastStopHeight, "K1 last stop height"                       ; K1 last stop height 
G1 E-1                                                                             ; Probe bed with a Single Z-Probe
; step 2 - probe multipule times on alvin and return offset value.
G1 X{var.Xanvil_position} Y{var.Yanvil_position} F18000                      ; Move bed probe to alvin
G30 K0 P0 Z-9999
set var.avg = sensors.probes[0].lastStopHeight
G30 K0 P1 Z-9999 S-1
set var.avg = var.avg + sensors.probes[0].lastStopHeight 
;G30 K0 P2 Z-9999 S-1
;set var.avg = var.avg + sensors.probes[0].lastStopHeight
echo var.avg/2, "avg / 2"                                                          ; Display average result
G31 K0 Z{var.avg/2}                                                                ; Set K0 offst with average vlue                                                                                                                                                               ; set Z K0 offset 
G31 K1 Z{var.avg/2}                                                                ; Set K1 offst with average vlue                                                                                                                                                         ; set Z K1 offset
G1 X155 Y40 Z15                                                                    ; Move away from anvil                                                                                                                                                                ; Move toolhead and bed down to Z25
; step 3 - leave bed probe
M98 P"/macros/nozzle_park"
G1 E-2 F300                                                                        ; Small retraction to stop ooze
M400
M98 P"/macros/nozzle_brush"                                                        ; Probe nozzle
; step 5 - probe  Tool switch
G1 X{var.Xtoolswitch_position} Y{var.Ytoolswitch_position}  F{var.speed}         ; Move nozzle to probe bed switch

;~~~~~ Check for oozing from the nozzle ,need a loop to check tool probe ~~~~~
while true
    ; 1. Check loop limit first (uses == for comparison)
    if iterations == 3 
        M98 P"/macros/nozzle_park" 
        abort "Too many auto calibration attempts" 

    ; 2. Take first probe reading
    G30 K1 
    var reading1 = sensors.probes[1].lastStopHeight 
    echo "K1 Reading 1:", var.reading1 

    ; 3. Take second probe reading
    G30 K1 
    var reading2 = sensors.probes[1].lastStopHeight 
    echo "K1 Reading 2:", var.reading2 

    ; 4. Check deviation limits
    if abs(var.reading1 - var.reading2) > 0.03 
        M98 P"/macros/nozzle_brush" 
        G1 X{var.Xtoolswitch_position} Y{var.Ytoolswitch_position F{var.speed} ; move nozzle to probe bed switch
        continue                                                                   ; Restarts the loop, skipping the break below

    ; 5. Success condition (breaks loop if deviation is <= 0.03)
    echo "Consistency achieved. Exiting loop."
    break 



G1 Z15                                                                             ; move bed down 
echo sensors.probes[0].lastStopHeight, "K0 last stop height"
echo sensors.probes[1].lastStopHeight, "K1 last stop height"
G1  X{var.position_tool_switchX} Y15 F24000                                        ; get nozzel back into bed area0
