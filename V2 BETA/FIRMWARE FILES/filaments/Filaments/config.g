var filament_type = "filament_name"	; filament type
var toolT = 250                     ; set hotend temperature     
var dryboxT = 40                    ; set dry box temperature    
var purge_length = 100              ; set the length of filament to purge
var extruder_purge_speed = 300      ; purge speed in mm/min
var load_time_buffer = 20           ; load buffer time in seconds   
